# ============================================================
# 沈幼楚 - 环境变量配置
# 复制此文件为 .env 并填入你的密钥
# cp .env.example .env
# ============================================================

# ─── 视觉 API（图片理解）─────────────────────────
# 通义千问 Qwen3-VL-Plus，阿里云 MaaS 工作区
VISION_PROVIDER=qwen
# VISION_API_KEY=sk-ws-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── 语音 ASR（语音转文字）────────────────────────
# local = 本地 Whisper，免费离线，不需要 API Key
ASR_PROVIDER=local

# ─── 语音 TTS（文字转语音）────────────────────────
# 阿里云 CosyVoice，和视觉 API 用同一个 Key 即可
# TTS_API_KEY=sk-ws-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 如果 MaaS 工作区不支持 CosyVoice，需单独开通 Dashscope：
# TTS_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/text2audio/cosyvoice

# ─── 城市配置 ──────────────────────────────────────
# CITY=广州
# CITY_LAT=23.13
# CITY_LON=113.26
