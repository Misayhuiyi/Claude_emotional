# ============================================================
# 沈幼楚 - 环境变量配置
# 复制此文件为 .env 并填入你的密钥
# cp .env.example .env
# ============================================================

# ─── 视觉 API（图片理解，三选一）────────────────────
# 推荐用通义千问 Qwen-VL，阿里云有免费额度
# https://help.aliyun.com/zh/model-studio/
# VISION_PROVIDER=qwen
# VISION_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# VISION_PROVIDER=glm
# VISION_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# VISION_PROVIDER=doubao
# VISION_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── 语音 ASR（语音转文字）────────────────────────
# local = 本地 Whisper（faster-whisper，免费，不需要 API Key）
# 首次使用会自动下载模型（约 1.4GB）
ASR_PROVIDER=local

# 或者使用云端 API：
# OpenAI Whisper：https://platform.openai.com/api-keys
# ASR_PROVIDER=whisper
# ASR_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Azure Speech：https://portal.azure.com/
# ASR_PROVIDER=azure
# ASR_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ASR_REGION=eastasia

# 阿里云语音识别
# ASR_PROVIDER=aliyun
# ASR_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── 语音 TTS（文字转语音，三选一）─────────────────
# Azure TTS（推荐，有免费层）
# TTS_PROVIDER=azure
# TTS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TTS_REGION=eastasia

# 阿里云 TTS
# TTS_PROVIDER=aliyun
# TTS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ElevenLabs TTS
# TTS_PROVIDER=elevenlabs
# TTS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── 主动推送配置 ──────────────────────────────────
# 城市（用于天气推送，默认广州）
# CITY=广州
# CITY_LAT=23.13
# CITY_LON=113.26
